    <Color x:Key="TabItemHeaderForegroundSelectedPressed">#1A1A1A</Color>
    
    <!-- Disabled State -->
    <Color x:Key="TabItemHeaderBackgroundDisabled">#F5F5F5</Color>
    <Color x:Key="TabItemHeaderForegroundDisabled">#CCCCCC</Color>
    
    <!-- Selected Pipe Indicator -->
    <Color x:Key="TabItemHeaderSelectedPipeFill">#1A1A1A</Color>
    
    <!-- Rich Text Separation Line -->
    <Color x:Key="RichTextSeparationLineColor">#E5E5E5</Color>
    
    <!-- Syntax Highlighting Colors -->
    <Color x:Key="SyntaxKeyword">#0000FF</Color>
    <Color x:Key="SyntaxComment">#008000</Color>
    <Color x:Key="SyntaxString">#A31515</Color>
    <Color x:Key="SyntaxTag">#800080</Color>
    <Color x:Key="SyntaxEntity">#FF0000</Color>
    <Color x:Key="SyntaxSelector">#800000</Color>
    <Color x:Key="SyntaxProperty">#FF8C00</Color>
    
    <!-- Rich Text Highlighting -->
    <Color x:Key="HighlightedText">#E5E5E5</Color>
    <Color x:Key="SearchMatchHighlight">#FBDCAB</Color>
    <!-- Inline text highlight (formatting toolbar marker) -->
    <Color x:Key="InlineHighlightColor">#FFD7AA</Color>

    <!-- Block Editor - drop line -->
    <Color x:Key="BlockEditorDropLineBrush">#E5E5E5</Color>

    <!-- Generic border (card/panel dividers) -->
    <Color x:Key="Border">#E5E5E5</Color>
    <!-- Block quote vertical line -->
    <Color x:Key="QuoteLine">#e95b45</Color>
    <!-- Primary accent (icons, highlights) -->
    <Color x:Key="AccentPrimary">#e95b45</Color>
    <!-- Mindmap -->
    <Color x:Key="MindmapNodeBorder">#e95b45</Color>
    <Color x:Key="MindmapNodeBorderHover">#FF6B55</Color>
    <Color x:Key="MindmapNodeBorderSelected">#D14F3B</Color>
    <Color x:Key="MindmapNodeBackgroundHover">#FFF0EE</Color>
    <Color x:Key="MindmapEdgeStroke">#888888</Color>
    <Color x:Key="MindmapGridColor">#40000000</Color>
    <!-- Mindmap toolbar (floating panel) -->
    <Color x:Key="MindmapToolbarPanelBackground">#FAFAF9</Color>
    <Color x:Key="MindmapToolbarSectionBackground">#FFFFFF</Color>
    <Color x:Key="MindmapToolbarLabel">#5C5B5A</Color>
    <Color x:Key="MindmapToolbarIcon">#5C5B5A</Color>
    <Color x:Key="MindmapToolbarBorder">#E2E1E0</Color>
    <Color x:Key="MindmapToolbarTabActiveBackground">#E8E7E6</Color>
    <Color x:Key="MindmapToolbarTabActiveForeground">#1A1A1A</Color>
    <Color x:Key="MindmapToolbarButtonHover">#EEEDEC</Color>
    <!-- Mindmap toolbar node color swatches; 1 = default (null color) for new nodes -->
    <Color x:Key="MindmapToolbarNodeColorSwatchOne">#888888</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchTwo">#e95b45</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchThree">#2686C2</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchFour">#6DA861</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchFive">#EAB308</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchSix">#886ce4</Color>
    <!-- Mindmap mode switcher (Edit | Preview bar) - aligned with ViewSwitchButtonActive / app accent -->
    <Color x:Key="MindmapModeSwitcherBorder">#E2E1E0</Color>
    <Color x:Key="MindmapModeSwitcherInactiveBackground">#EBEAE9</Color>
    <Color x:Key="MindmapModeSwitcherActiveBackground">#e95b45</Color>
    <Color x:Key="MindmapModeSwitcherActiveForeground">#FFFFFF</Color>
    <Color x:Key="MindmapModeSwitcherInactiveForeground">#5C5B5A</Color>

    <!-- Inline text color swatches (foreground) -->
    <Color x:Key="TextColorSwatch1">#57534E</Color>
    <Color x:Key="TextColorSwatch2">#7C3AED</Color>
    <Color x:Key="TextColorSwatch3">#2563EB</Color>
    <Color x:Key="TextColorSwatch4">#9333EA</Color>
    <Color x:Key="TextColorSwatch5">#DC2626</Color>
    <Color x:Key="TextColorSwatch6">#16A34A</Color>
    <Color x:Key="TextColorSwatch7">#CA8A04</Color>
    <Color x:Key="TextColorSwatch8">#EA580C</Color>
    <Color x:Key="TextColorSwatch9">#0284C7</Color>
    <Color x:Key="TextColorSwatch10">#0D9488</Color>

    <!-- Inline background color swatches -->
    <Color x:Key="ColorSwatch1">#F5F5F5</Color>
    <Color x:Key="ColorSwatch2">#E6E6FA</Color>
    <Color x:Key="ColorSwatch3">#D8DCEC</Color>
    <Color x:Key="ColorSwatch4">#C4B5FD</Color>
    <Color x:Key="ColorSwatch5">#FADBD8</Color>
    <Color x:Key="ColorSwatch6">#E8F5E9</Color>
    <Color x:Key="ColorSwatch7">#FFF3CD</Color>
    <Color x:Key="ColorSwatch8">#FFE0B2</Color>
    <Color x:Key="ColorSwatch9">#DBEAFE</Color>
    <Color x:Key="ColorSwatch10">#D1EDDA</Color>

    <!-- Notes module (pane, section headers, editor) -->
    <Color x:Key="BlockSelectionBackground">#FDECEA</Color>
    <Color x:Key="NotesPaneBackground">#FAFAF9</Color>
    <Color x:Key="NotesSectionHeaderForeground">#5C5B5A</Color>
    <Color x:Key="NotesPaneDivider">#EBEAE9</Color>
    <Color x:Key="NotesEditorSeparator">#EBEAE9</Color>

    <!-- Code syntax highlighting (TextMate scopes → brushes in Controls.axaml) -->
    <Color x:Key="SyntaxCodeDefault">#1A1A1A</Color>
    <Color x:Key="SyntaxCodeKeyword">#6F42C1</Color>
    <Color x:Key="SyntaxCodeString">#0B6E0B</Color>
    <Color x:Key="SyntaxCodeComment">#6A737D</Color>
    <Color x:Key="SyntaxCodeNumber">#0550AE</Color>
    <Color x:Key="SyntaxCodeType">#0077C8</Color>
    <Color x:Key="SyntaxCodeFunction">#6639B7</Color>
    <Color x:Key="SyntaxCodeOperator">#A40E26</Color>
    <Color x:Key="SyntaxCodePunctuation">#57606A</Color>
    <Color x:Key="SyntaxCodeVariable">#24292F</Color>
    <Color x:Key="SyntaxCodeMarkup">#116329</Color>
    <Color x:Key="SyntaxCodeInvalid">#D1242F</Color>

    <!-- Slider -->
    <Color x:Key="SliderTrackFill">#E5E5E5</Color>
    <Color x:Key="SliderTrackValueFill">#e95b45</Color>
    <Color x:Key="SliderThumbBackground">#FFFFFF</Color>
    <Color x:Key="SliderThumbBorder">#E5E5E5</Color>
    <Color x:Key="SliderTickBarFill">#CCCCCC</Color>
    <Color x:Key="SliderContainerBackground">Transparent</Color>
    
    <!-- Slider PointerOver -->
    <Color x:Key="SliderTrackFillPointerOver">#D5D5D5</Color>
    <Color x:Key="SliderTrackValueFillPointerOver">#FF6B55</Color>
    <Color x:Key="SliderThumbBackgroundPointerOver">#F5F5F5</Color>
    <Color x:Key="SliderContainerBackgroundPointerOver">Transparent</Color>
    
    <!-- Slider Pressed -->
    <Color x:Key="SliderTrackFillPressed">#BBBBBB</Color>
    <Color x:Key="SliderTrackValueFillPressed">#D14F3B</Color>
    <Color x:Key="SliderThumbBackgroundPressed">#E5E5E5</Color>
    <Color x:Key="SliderContainerBackgroundPressed">Transparent</Color>
    
    <!-- Slider Disabled -->
    <Color x:Key="SliderTrackFillDisabled">#F5F5F5</Color>
    <Color x:Key="SliderTrackValueFillDisabled">#CCCCCC</Color>
    <Color x:Key="SliderThumbBackgroundDisabled">#F5F5F5</Color>
    <Color x:Key="SliderTickBarFillDisabled">#E5E5E5</Color>
    <Color x:Key="SliderContainerBackgroundDisabled">Transparent</Color>
</ResourceDictionary>