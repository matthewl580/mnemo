    <Color x:Key="Border">#312e2d</Color>
    <!-- Block quote vertical line -->
    <Color x:Key="QuoteLine">#e95b45</Color>
    <!-- Primary accent (icons, highlights) -->
    <Color x:Key="AccentPrimary">#e95b45</Color>
    <!-- Mindmap -->
    <Color x:Key="MindmapNodeBorder">#e95b45</Color>
    <Color x:Key="MindmapNodeBorderHover">#FF6B55</Color>
    <Color x:Key="MindmapNodeBorderSelected">#D14F3B</Color>
    <Color x:Key="MindmapNodeBackgroundHover">#464549</Color>
    <Color x:Key="MindmapEdgeStroke">#797573</Color>
    <Color x:Key="MindmapGridColor">#40FFFFFF</Color>
    <!-- Mindmap toolbar (floating panel) -->
    <Color x:Key="MindmapToolbarPanelBackground">#2A2827</Color>
    <Color x:Key="MindmapToolbarSectionBackground">#363432</Color>
    <Color x:Key="MindmapToolbarLabel">#9A9896</Color>
    <Color x:Key="MindmapToolbarIcon">#AAAAAA</Color>
    <Color x:Key="MindmapToolbarBorder">#3D3B3A</Color>
    <Color x:Key="MindmapToolbarTabActiveBackground">#464549</Color>
    <Color x:Key="MindmapToolbarTabActiveForeground">#E8E7E6</Color>
    <Color x:Key="MindmapToolbarButtonHover">#404044</Color>
    <!-- Mindmap toolbar node color swatches; 1 = default (null color) for new nodes -->
    <Color x:Key="MindmapToolbarNodeColorSwatchOne">#797573</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchTwo">#e95b45</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchThree">#2686C2</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchFour">#6DA861</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchFive">#EAB308</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchSix">#886ce4</Color>
    <!-- Mindmap mode switcher (Edit | Preview bar) - aligned with ViewSwitchButtonActive / app accent -->
    <Color x:Key="MindmapModeSwitcherBorder">#3D3B3A</Color>
    <Color x:Key="MindmapModeSwitcherInactiveBackground">#2E2D2C</Color>
    <Color x:Key="MindmapModeSwitcherActiveBackground">#e95b45</Color>
    <Color x:Key="MindmapModeSwitcherActiveForeground">#FFFFFF</Color>
    <Color x:Key="MindmapModeSwitcherInactiveForeground">#9A9896</Color>

    <!-- Slider -->
    <Color x:Key="SliderTrackFill">#464549</Color>
    <Color x:Key="SliderTrackValueFill">#e95b45</Color>
    <Color x:Key="SliderThumbBackground">#5C5B5A</Color>
    <Color x:Key="SliderThumbBorder">#3D3B3A</Color>
    <Color x:Key="SliderTickBarFill">#5C5B5A</Color>
    <Color x:Key="SliderContainerBackground">Transparent</Color>
    <!-- Slider PointerOver -->
    <Color x:Key="SliderTrackFillPointerOver">#5C5B5A</Color>
    <Color x:Key="SliderTrackValueFillPointerOver">#FF6B55</Color>
    <Color x:Key="SliderThumbBackgroundPointerOver">#6A6968</Color>
    <Color x:Key="SliderContainerBackgroundPointerOver">Transparent</Color>
    <!-- Slider Pressed -->
    <Color x:Key="SliderTrackFillPressed">#363432</Color>
    <Color x:Key="SliderTrackValueFillPressed">#D14F3B</Color>
    <Color x:Key="SliderThumbBackgroundPressed">#5C5B5A</Color>
    <Color x:Key="SliderContainerBackgroundPressed">Transparent</Color>
    <!-- Slider Disabled -->
    <Color x:Key="SliderTrackFillDisabled">#2A2827</Color>
    <Color x:Key="SliderTrackValueFillDisabled">#464549</Color>
    <Color x:Key="SliderThumbBackgroundDisabled">#3D3B3A</Color>
    <Color x:Key="SliderTickBarFillDisabled">#3D3B3A</Color>
    <Color x:Key="SliderContainerBackgroundDisabled">Transparent</Color>

    <!-- Color Swatches -->
    <!-- Inline text color swatches (foreground) -->
    <Color x:Key="TextColorSwatch1">#CFCCCB</Color>
    <Color x:Key="TextColorSwatch2">#C4B5FD</Color>
    <Color x:Key="TextColorSwatch3">#93C5FD</Color>
    <Color x:Key="TextColorSwatch4">#D8B4FE</Color>
    <Color x:Key="TextColorSwatch5">#FDA4AF</Color>
    <Color x:Key="TextColorSwatch6">#86EFAC</Color>
    <Color x:Key="TextColorSwatch7">#FDE047</Color>
    <Color x:Key="TextColorSwatch8">#FDBA74</Color>
    <Color x:Key="TextColorSwatch9">#7DD3FC</Color>
    <Color x:Key="TextColorSwatch10">#5EEAD4</Color>

    <!-- Inline background color swatches -->
    <Color x:Key="ColorSwatch1">#3A3A3D</Color>
    <Color x:Key="ColorSwatch2">#40304D</Color>
    <Color x:Key="ColorSwatch3">#293645</Color>
    <Color x:Key="ColorSwatch4">#422659</Color>
    <Color x:Key="ColorSwatch5">#542025</Color>
    <Color x:Key="ColorSwatch6">#25452C</Color>
    <Color x:Key="ColorSwatch7">#52451A</Color>
    <Color x:Key="ColorSwatch8">#593617</Color>
    <Color x:Key="ColorSwatch9">#1E3A5F</Color>
    <Color x:Key="ColorSwatch10">#1B4235</Color>

    <!-- Notes module (pane, section headers, editor) -->
    <Color x:Key="BlockSelectionBackground">#4A2520</Color>
    <Color x:Key="NotesPaneBackground">#1C1B1A</Color>
    <Color x:Key="NotesSectionHeaderForeground">#9A9694</Color>
    <Color x:Key="NotesPaneDivider">#2E2D2C</Color>
    <Color x:Key="NotesEditorSeparator">#2E2D2C</Color>

    <!-- Code syntax highlighting -->
    <Color x:Key="SyntaxCodeDefault">#D4D4D4</Color>
    <Color x:Key="SyntaxCodeKeyword">#C586C0</Color>
    <Color x:Key="SyntaxCodeString">#CE9178</Color>
    <Color x:Key="SyntaxCodeComment">#6A9955</Color>
    <Color x:Key="SyntaxCodeNumber">#B5CEA8</Color>
    <Color x:Key="SyntaxCodeType">#4EC9B0</Color>
    <Color x:Key="SyntaxCodeFunction">#DCDCAA</Color>
    <Color x:Key="SyntaxCodeOperator">#D4D4D4</Color>
    <Color x:Key="SyntaxCodePunctuation">#9D9D9D</Color>
    <Color x:Key="SyntaxCodeVariable">#9CDCFE</Color>
    <Color x:Key="SyntaxCodeMarkup">#569CD6</Color>
    <Color x:Key="SyntaxCodeInvalid">#F44747</Color>
</ResourceDictionary>




