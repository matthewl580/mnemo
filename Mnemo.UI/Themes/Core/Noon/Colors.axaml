    <Color x:Key="RichTextSeparationLineColor">#EADFCB</Color>
    
    <!-- Syntax Highlighting Colors -->
    <Color x:Key="SyntaxKeyword">#0000FF</Color>
    <Color x:Key="SyntaxComment">#008000</Color>
    <Color x:Key="SyntaxString">#A31515</Color>
    <Color x:Key="SyntaxTag">#800080</Color>
    <Color x:Key="SyntaxEntity">#FF0000</Color>
    <Color x:Key="SyntaxSelector">#800000</Color>
    <Color x:Key="SyntaxProperty">#FF8C00</Color>
    
    <!-- Rich Text Highlighting -->
    <Color x:Key="HighlightedText">#FFE2CF</Color>
    <Color x:Key="SearchMatchHighlight">#FBDCAB</Color>
    <Color x:Key="InlineHighlightColor">#EEEAFF</Color>

    <!-- Block Editor - drop line -->
    <Color x:Key="BlockEditorDropLineBrush">#E9573F</Color>

    <!-- Generic border (card/panel dividers) -->
    <Color x:Key="Border">#EADFCB</Color>
    <!-- Block quote vertical line -->
    <Color x:Key="QuoteLine">#E9573F</Color>
    <!-- Primary accent (icons, highlights) -->
    <Color x:Key="AccentPrimary">#E9573F</Color>
    <!-- Mindmap -->
    <Color x:Key="MindmapNodeBorder">#EADFCB</Color>
    <Color x:Key="MindmapNodeBorderHover">#F19B75</Color>
    <Color x:Key="MindmapNodeBorderSelected">#E9573F</Color>
    <Color x:Key="MindmapNodeBackgroundHover">#FBF8F0</Color>
    <Color x:Key="MindmapEdgeStroke">#C9B99F</Color>
    <Color x:Key="MindmapGridColor">#40000000</Color>
    <!-- Mindmap toolbar (floating panel) -->
    <Color x:Key="MindmapToolbarPanelBackground">#FFFDF8</Color>
    <Color x:Key="MindmapToolbarSectionBackground">#FFFFFF</Color>
    <Color x:Key="MindmapToolbarLabel">#57534E</Color>
    <Color x:Key="MindmapToolbarIcon">#57534E</Color>
    <Color x:Key="MindmapToolbarBorder">#EADFCB</Color>
    <Color x:Key="MindmapToolbarTabActiveBackground">#F5EFE3</Color>
    <Color x:Key="MindmapToolbarTabActiveForeground">#24201A</Color>
    <Color x:Key="MindmapToolbarButtonHover">#F5EFE3</Color>
    <!-- Mindmap toolbar node color swatches -->
    <Color x:Key="MindmapToolbarNodeColorSwatchOne">#78716C</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchTwo">#E9573F</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchThree">#2686C2</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchFour">#6DA861</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchFive">#EAB308</Color>
    <Color x:Key="MindmapToolbarNodeColorSwatchSix">#886CE4</Color>
    <!-- Mindmap mode switcher -->
    <Color x:Key="MindmapModeSwitcherBorder">#EADFCB</Color>
    <Color x:Key="MindmapModeSwitcherInactiveBackground">#F5EFE3</Color>
    <Color x:Key="MindmapModeSwitcherActiveBackground">#E9573F</Color>
    <Color x:Key="MindmapModeSwitcherActiveForeground">#FFFFFF</Color>
    <Color x:Key="MindmapModeSwitcherInactiveForeground">#57534E</Color>

    <!-- Inline text color swatches (foreground) -->
    <Color x:Key="TextColorSwatch1">#57534E</Color>
    <Color x:Key="TextColorSwatch2">#6D28D9</Color>
    <Color x:Key="TextColorSwatch3">#1D4ED8</Color>
    <Color x:Key="TextColorSwatch4">#7E22CE</Color>
    <Color x:Key="TextColorSwatch5">#B91C1C</Color>
    <Color x:Key="TextColorSwatch6">#15803D</Color>
    <Color x:Key="TextColorSwatch7">#A16207</Color>
    <Color x:Key="TextColorSwatch8">#C2410C</Color>
    <Color x:Key="TextColorSwatch9">#0369A1</Color>
    <Color x:Key="TextColorSwatch10">#0F766E</Color>

    <!-- Inline background color swatches -->
    <Color x:Key="ColorSwatch1">#FBF8F0</Color>
    <Color x:Key="ColorSwatch2">#EEEAFF</Color>
    <Color x:Key="ColorSwatch3">#D8DCEC</Color>
    <Color x:Key="ColorSwatch4">#C4B5FD</Color>
    <Color x:Key="ColorSwatch5">#FFE2CF</Color>
    <Color x:Key="ColorSwatch6">#E8F5E9</Color>
    <Color x:Key="ColorSwatch7">#FFF3CD</Color>
    <Color x:Key="ColorSwatch8">#FFE0B2</Color>
    <Color x:Key="ColorSwatch9">#DBEAFE</Color>
    <Color x:Key="ColorSwatch10">#D1EDDA</Color>

    <!-- Notes module (pane, section headers, editor) -->
    <Color x:Key="BlockSelectionBackground">#FFE2CF</Color>
    <Color x:Key="NotesPaneBackground">#fcfbf9</Color>
    <Color x:Key="NotesSectionHeaderForeground">#57534E</Color>
    <Color x:Key="NotesPaneDivider">#EADFCB</Color>
    <Color x:Key="NotesEditorSeparator">#EADFCB</Color>

    <!-- Code syntax highlighting -->
    <Color x:Key="SyntaxCodeDefault">#292524</Color>
    <Color x:Key="SyntaxCodeKeyword">#6B3FA0</Color>
    <Color x:Key="SyntaxCodeString">#166534</Color>
    <Color x:Key="SyntaxCodeComment">#78716C</Color>
    <Color x:Key="SyntaxCodeNumber">#B45309</Color>
    <Color x:Key="SyntaxCodeType">#0C4A6E</Color>
    <Color x:Key="SyntaxCodeFunction">#7C3AED</Color>
    <Color x:Key="SyntaxCodeOperator">#B91C1C</Color>
    <Color x:Key="SyntaxCodePunctuation">#57534E</Color>
    <Color x:Key="SyntaxCodeVariable">#292524</Color>
    <Color x:Key="SyntaxCodeMarkup">#15803D</Color>
    <Color x:Key="SyntaxCodeInvalid">#DC2626</Color>

    <!-- Slider -->
    <Color x:Key="SliderTrackFill">#EFE5D5</Color>
    <Color x:Key="SliderTrackValueFill">#E9573F</Color>
    <Color x:Key="SliderThumbBackground">#FFFFFF</Color>
    <Color x:Key="SliderThumbBorder">#EADFCB</Color>
    <Color x:Key="SliderTickBarFill">#A8A29E</Color>
    <Color x:Key="SliderContainerBackground">Transparent</Color>
    
    <!-- Slider PointerOver -->
    <Color x:Key="SliderTrackFillPointerOver">#EADFCB</Color>
    <Color x:Key="SliderTrackValueFillPointerOver">#F19B75</Color>
    <Color x:Key="SliderThumbBackgroundPointerOver">#FBF8F0</Color>
    <Color x:Key="SliderContainerBackgroundPointerOver">Transparent</Color>
    
    <!-- Slider Pressed -->
    <Color x:Key="SliderTrackFillPressed">#C9B99F</Color>
    <Color x:Key="SliderTrackValueFillPressed">#D94B33</Color>
    <Color x:Key="SliderThumbBackgroundPressed">#EFE4D2</Color>
    <Color x:Key="SliderContainerBackgroundPressed">Transparent</Color>
    
    <!-- Slider Disabled -->
    <Color x:Key="SliderTrackFillDisabled">#FBF8F0</Color>
    <Color x:Key="SliderTrackValueFillDisabled">#D6D3D1</Color>
    <Color x:Key="SliderThumbBackgroundDisabled">#FBF8F0</Color>
    <Color x:Key="SliderTickBarFillDisabled">#EFE5D5</Color>
    <Color x:Key="SliderContainerBackgroundDisabled">Transparent</Color>
</ResourceDictionary>