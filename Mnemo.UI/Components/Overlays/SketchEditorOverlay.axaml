<UserControl
    x:Class="Mnemo.UI.Components.Overlays.SketchEditorOverlay"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Mnemo.UI.Controls"
    x:CompileBindings="False">
    <Grid Margin="8" Background="Transparent">
        <Border
            x:Name="ShellCard"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MinWidth="280"
            MinHeight="200"
            Background="{DynamicResource OverlayBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Padding="16">
            <Grid RowDefinitions="Auto,16,*,16,Auto">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Text="Edit Sketch diagram" />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Width="34"
                        Height="34"
                        Padding="0"
                        BorderThickness="0"
                        Background="Transparent"
                        CornerRadius="17"
                        Cursor="Hand"
                        Click="CancelButton_Click">
                        <controls:SvgIcon
                            Width="16"
                            Height="16"
                            SvgPath="avares://Mnemo.UI/Icons/Common/x.svg"
                            Color="{DynamicResource TextSecondaryBrush}" />
                    </Button>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="*,16,*">
                    <Border
                        Background="{DynamicResource CardBackgroundSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                        <Grid RowDefinitions="Auto,8,*">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Text="Source" />
                            <ScrollViewer
                                x:Name="SourceScroll"
                                Grid.Row="2"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto"
                                Background="{DynamicResource TextControlBackgroundBrush}">
                                <Grid MinHeight="0">
                                    <controls:TextSelectionBackgroundLayer
                                        x:Name="SourceSelectionBackground"
                                        ZIndex="0"
                                        IsHitTestVisible="False"
                                        FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                                        FontSize="13"
                                        LineHeight="20"
                                        SelectionBrush="{DynamicResource TextControlSelectionHighlightColorBrush}"
                                        TextPadding="10,8,10,10"
                                        TextWrapping="NoWrap" />
                                    <TextBlock
                                        x:Name="SourceHighlightBlock"
                                        ZIndex="1"
                                        Padding="10,8,10,10"
                                        FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                                        FontSize="13"
                                        LineHeight="20"
                                        TextWrapping="NoWrap"
                                        Foreground="{DynamicResource SyntaxCodeDefaultBrush}"
                                        IsHitTestVisible="False" />
                                    <TextBox
                                        x:Name="SourceTextBox"
                                        ZIndex="2"
                                        AcceptsReturn="True"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                                        FontSize="13"
                                        LineHeight="20"
                                        Foreground="Transparent"
                                        CaretBrush="{DynamicResource TextControlForegroundBrush}"
                                        SelectionBrush="Transparent"
                                        SelectionForegroundBrush="Transparent"
                                        Padding="10,8,10,10"
                                        TextWrapping="NoWrap"
                                        TextChanged="SourceTextBox_TextChanged" />
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Background="{DynamicResource CardBackgroundSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                        <Grid RowDefinitions="Auto,8,*,64">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="2">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Text="Preview" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="6">
                                    <Button
                                        Width="30"
                                        Height="28"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Padding="0"
                                        Content="-"
                                        Click="ZoomOutButton_Click" />
                                    <Button
                                        x:Name="ResetViewButton"
                                        Height="28"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Padding="10,0"
                                        Content="Reset"
                                        Click="ResetViewButton_Click" />
                                    <Button
                                        Width="30"
                                        Height="28"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Padding="0"
                                        Content="+"
                                        Click="ZoomInButton_Click" />
                                    <Border
                                        MinWidth="48"
                                        Padding="8,0"
                                        CornerRadius="14"
                                        Background="{DynamicResource SystemControlBackgroundChromeLowBrush}">
                                        <TextBlock
                                            x:Name="ZoomText"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                            <Border
                                x:Name="PreviewSurface"
                                Grid.Row="2"
                                Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                                ClipToBounds="True"
                                CornerRadius="8"
                                Cursor="Hand"
                                PointerPressed="PreviewSurface_PointerPressed"
                                PointerMoved="PreviewSurface_PointerMoved"
                                PointerReleased="PreviewSurface_PointerReleased"
                                PointerCaptureLost="PreviewSurface_PointerCaptureLost"
                                PointerWheelChanged="PreviewSurface_PointerWheelChanged">
                                <Grid Background="Transparent">
                                    <controls:SketchSvgView
                                        x:Name="Preview"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        IsHitTestVisible="False" />
                                </Grid>
                            </Border>
                            <ScrollViewer
                                Grid.Row="3"
                                Margin="0,8,0,0"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto"
                                Background="Transparent">
                                <TextBlock
                                    x:Name="DiagnosticsText"
                                    Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                    FontSize="12"
                                    IsVisible="False"
                                    TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="4" ColumnDefinitions="*,Auto,8,Auto">
                    <Button
                        Grid.Column="1"
                        Padding="16,8"
                        CornerRadius="18"
                        Cursor="Hand"
                        Content="Cancel"
                        Click="CancelButton_Click" />
                    <Button
                        x:Name="SaveButton"
                        Grid.Column="3"
                        Padding="18,8"
                        CornerRadius="18"
                        Cursor="Hand"
                        Content="Save diagram"
                        Click="SaveButton_Click" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
