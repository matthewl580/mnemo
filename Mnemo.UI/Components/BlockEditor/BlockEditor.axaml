<UserControl
    x:Class="Mnemo.UI.Components.BlockEditor.BlockEditor"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Mnemo.UI.Components.BlockEditor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:CompileBindings="False"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    DragDrop.AllowDrop="True"
    Background="Transparent"
    VerticalAlignment="Stretch"
    ClipToBounds="False"
    Cursor="IBeam">
    <Grid Background="Transparent" Cursor="IBeam">
        <Border Background="Transparent" ClipToBounds="False" Padding="32,0,32,0" DragDrop.AllowDrop="True">
            <Grid Background="Transparent">
                <Grid x:Name="EditorRoot" RowDefinitions="Auto,Auto" Background="Transparent" ClipToBounds="False">
                    <!--
                        ItemsRepeater (not ItemsControl) is used here for vertical UI virtualization: only rows in
                        the visible viewport (plus a small buffer) are realized. With 1500+ blocks this turns
                        thousands of EditableBlock + RichTextEditor + TextLayout allocations into ~30. See
                        ChatView.axaml for the same pattern; ItemsControl + VirtualizingStackPanel does not
                        virtualize inside this ScrollViewer > StackPanel chain.

                        The ContentControl wrapper exists so we can keep two data templates (single block row
                        vs. split-column row) without writing a custom IDataTemplate — ContentControl resolves
                        its DataTemplates against the bound row type.
                    -->
                    <ItemsRepeater x:Name="BlocksItemsControl" Grid.Row="0" ItemsSource="{Binding BlockRows}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="6" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}"
                                                MinHeight="{Binding LayoutHeightHint}"
                                                HorizontalAlignment="Stretch"
                                                Padding="0"
                                                Margin="0">
                                    <ContentControl.DataTemplates>
                                        <DataTemplate DataType="local:SingleBlockRowViewModel">
                                            <local:EditableBlock DataContext="{Binding Block}" />
                                        </DataTemplate>
                                        <DataTemplate DataType="local:SplitBlockRowViewModel">
                                            <local:SplitBlockRowView />
                                        </DataTemplate>
                                    </ContentControl.DataTemplates>
                                </ContentControl>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <!-- Hit target below last block; keep modest so the page does not show a huge empty band. -->
                    <Border x:Name="BelowBlocksArea" Grid.Row="1" MinHeight="56" Background="Transparent" DragDrop.AllowDrop="True" />
                </Grid>
                <!-- Overlay inside padded Border so (0,0) = content area; selection box coords match GetPosition(overlay). -->
                <local:LayoutOverlayPanel x:Name="SelectionBoxOverlay" IsHitTestVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Border
                        x:Name="SelectionBoxBorder"
                        Background="{DynamicResource AccentPrimaryBrush}"
                        Opacity="0.15"
                        BorderBrush="{DynamicResource AccentPrimaryBrush}"
                        BorderThickness="1"
                        IsVisible="False"
                        IsHitTestVisible="False" />
                </local:LayoutOverlayPanel>
                <local:LayoutOverlayPanel x:Name="BlockDragGhostOverlay" IsHitTestVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <!-- Horizontal reorder insert line: positioned in overlay space (same as drag ghost). -->
                    <Border
                        x:Name="BlockReorderDropLineOverlay"
                        Height="3"
                        CornerRadius="1"
                        Background="{DynamicResource BlockEditorDropLineBrush}"
                        IsHitTestVisible="False"
                        IsVisible="False" />
                </local:LayoutOverlayPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>






