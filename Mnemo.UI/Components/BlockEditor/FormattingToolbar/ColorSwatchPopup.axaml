<UserControl
    x:Class="Mnemo.UI.Components.BlockEditor.FormattingToolbar.ColorSwatchPopup"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:CompileBindings="False"
    Focusable="False">
    <UserControl.Styles>
        <Style Selector="Border.color-mode-track">
            <Setter Property="Background" Value="{DynamicResource WidgetBackgroundPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="3" />
        </Style>
        <Style Selector="Button.color-mode-segment">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.color-mode-segment:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource WidgetBackgroundHoverBrush}" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.color-mode-segment.selected">
            <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.color-mode-segment.selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource WorkspaceBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.color-mode-segment.selected TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Styles>

    <Border
        MinWidth="248"
        Background="{DynamicResource WorkspaceBackgroundBrush}"
        BorderBrush="{DynamicResource ButtonBorderBrush}"
        BorderThickness="1"
        BoxShadow="0 4 16 0 #18000000, 0 1 4 0 #10000000"
        CornerRadius="10"
        Padding="12,10">
        <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock
                    x:Name="TitleLabel"
                    Grid.Column="0"
                    Text="Color"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    VerticalAlignment="Center" />

                <Border Grid.Column="1" Classes="color-mode-track">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button
                            x:Name="TextModeButton"
                            Classes="color-mode-segment selected"
                            Click="OnTextModeClick">
                            <TextBlock x:Name="TextModeLabel" Text="Text" />
                        </Button>
                        <Button
                            x:Name="HighlightModeButton"
                            Classes="color-mode-segment"
                            Click="OnHighlightModeClick">
                            <TextBlock x:Name="HighlightModeLabel" Text="Highlight" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="6">
                <TextBlock
                    x:Name="PaletteHeaderLabel"
                    Text="PALETTE"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    LetterSpacing="0.5" />
                <WrapPanel x:Name="SwatchPanel" Orientation="Horizontal" MaxWidth="224" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
